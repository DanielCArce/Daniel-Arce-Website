---
import '../styles/global.css';
import PageHeader from '../components/PageHeader.astro';
import FooterSection from '../components/FooterSection.astro';
const { title = "Blog" } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes</title>
     <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-K6TKKCBL");
    </script>
    <!-- End Google Tag Manager -->
<meta
      name="title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      name="description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta
      name="keywords"
      content="contador, desarrollador de sotware en costa rica, fulstack developer, contador en heredia, sitio web, website, aplicaciones moviles, mobile apps, desktop apps"
    />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.danielcarce.com/" />
    <meta
      property="og:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      property="og:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://www.danielcarce.com/" />
    <meta
      name="twitter:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Costa Rica"
    />
    <meta
      name="twitter:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta
      name="twitter:image"
      content="https://danielcarce.com/og-image.png"
    />
