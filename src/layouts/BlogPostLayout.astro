---
import "../styles/global.css";
import PageHeader from "../components/PageHeader.astro";
import FooterSection from '../components/FooterSection.astro';
const { title, date, author, description, keywords, slug } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={`https://www.danielcarce.com/blog/${slug}`} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} Daniel Arce | Soluciones Contable Financieras y de Software Para Costa Rica</title>
     <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-K6TKKCBL");
    </script>
    <!-- End Google Tag Manager -->
    <meta name="description" content={description}/>
    <meta name="keywords" content={keywords.join()}/>
<meta
      name="title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      name="description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta
      name="keywords"
      content="contador, desarrollador de sotware en costa rica, fulstack developer, contador en heredia, sitio web, website, aplicaciones moviles, mobile apps, desktop apps"
    />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.danielcarce.com/" />
    <meta
      property="og:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      property="og:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://www.danielcarce.com/" />
    <meta
      name="twitter:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Costa Rica"
    />
    <meta
      name="twitter:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta
      name="twitter:image"
      content="https://danielcarce.com/og-image.png"
    />
<meta name="twitter:image" content="https://danielcarce.com/og-image.png">
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">
     <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-K6TKKCBL"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
<PageHeader/>
    <main class="max-w-5xl mx-auto px-6 py-12 prose">
      <article class="bg-white rounded-lg shadow p-8">
        <header class="mb-8">
          <h1 class="text-4xl font-bold text-gray-900 mb-2">{title}</h1>
          <p class="text-gray-500 text-sm">
            {date ? new Date(date).toLocaleDateString() : ""} 
            {author ? ` | por ${author}` : ""}
          </p>
        </header>

        <div class="max-w-full text-gray-800">
          <slot />
        </div>
      </article>
    </main>

    <FooterSection/>
  </body>
</html>
