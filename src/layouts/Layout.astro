---
import PageHeader from "../components/PageHeader.astro";
import FooterSection from "../components/FooterSection.astro";

// Dentro de tu Layout de Astro
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://www.danielcarce.com/#person",
      "name": "Daniel Arce",
      "url": "https://www.danielcarce.com",
      "jobTitle": [
        "Senior Software Engineer", 
        "Contador Privado", 
        "Accountant", 
        "Desarrollador de Software"
      ],
      "description": "Consultor integral para PYMES en Costa Rica. Especialista en la intersección de tecnología avanzada y precisión contable para optimización de negocios.",
      "sameAs": [
        "https://www.instagram.com/30thopps"
      ],
      "knowsAbout": [
        "Desarrollo de Software a Medida",
        "Contabilidad Financiera",
        "Contabilidad Gerencial",
        "Asesoría y Planificación Fiscal",
        "Automatización de Procesos (BPA)",
        "Integración de Sistemas",
        "Apps Móviles y de Escritorio",
        "Auditoría Interna de Procesos",
        "Transformación Digital"
      ]
    },
    {
      "@type": "ProfessionalService",
      "name": "30th Opps",
      "url": "https://www.danielcarce.com",
      "image": "https://danielcarce.com/og-image.png",
      "logo": "https://www.danielcarce.com/logo-30thopps.jpg", 
      "telephone": ["+50664857937", "+50686813736"],
      "priceRange": "$$",
      "founder": { "@id": "https://www.danielcarce.com/#person" },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+50664857937",
          "contactType": "WhatsApp",
          "availableLanguage": ["Spanish", "English"]
        },
        {
          "@type": "ContactPoint",
          "telephone": "+50686813736",
          "contactType": "customer service",
          "description": "Llamadas telefónicas",
          "availableLanguage": ["Spanish", "English"]
        }
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Heredia",
        "addressLocality": "Heredia",
        "addressRegion": "Heredia",
        "postalCode": "40101",
        "addressCountry": "CR"
      },
      "offers": [
        {
          "@type": "Service",
          "name": "Desarrollo de Software y Apps"
        },
        {
          "@type": "Service",
          "name": "Consultoría Contable y Fiscal"
        }
      ]
    }
  ]
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <title>
      Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes
    </title>
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-K6TKKCBL");
    </script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/png" href="/favicon-32x32.png" />
    <meta
      name="title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      name="description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta
      name="keywords"
      content="contador, desarrollador de sotware en costa rica, fullstack developer, contador en heredia, sitio web, website, aplicaciones moviles, mobile apps, desktop apps, contador en costa rica"
    />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.danielcarce.com/" />
    <meta
      property="og:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Pymes"
    />
    <meta
      property="og:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://www.danielcarce.com/" />
    <meta
      name="twitter:title"
      content="Daniel Arce | Soluciones Contables Financieras y de Software Para Costa Rica"
    />
    <meta
      name="twitter:description"
      content="Soluciones Integrales en Contabilidad Financiera y  Software Para Pymes de Costa Rica"
    />
    <meta name="twitter:image" content="https://danielcarce.com/og-image.png" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-K6TKKCBL"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <PageHeader companyName="Daniel C. Arce" />
    <main>
      <slot />
      <!-- your content is injected here -->
    </main>
    <FooterSection />
  </body>
  <style>
    h1 {
      font-size: 2rem;
    }
  </style>
</html>
